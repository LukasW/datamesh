{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductState",
  "description": "Compacted state representation of a product, used for snapshot/state topics.",
  "type": "object",
  "required": [
    "eventType",
    "productId",
    "name",
    "productLine",
    "basePremium",
    "status",
    "deleted",
    "timestamp"
  ],
  "additionalProperties": false,
  "properties": {
    "eventType": {
      "type": "string",
      "enum": ["ProductState"],
      "description": "Discriminator for the event type."
    },
    "productId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the product."
    },
    "name": {
      "type": "string",
      "description": "Human-readable product name."
    },
    "productLine": {
      "type": "string",
      "description": "Product line classification (e.g. household, liability)."
    },
    "basePremium": {
      "type": "number",
      "description": "Base premium amount before risk adjustments."
    },
    "status": {
      "type": "string",
      "description": "Current lifecycle status of the product (e.g. ACTIVE, DEPRECATED)."
    },
    "deleted": {
      "type": "boolean",
      "description": "Tombstone flag indicating whether the product has been logically deleted."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of the state snapshot."
    }
  }
}
