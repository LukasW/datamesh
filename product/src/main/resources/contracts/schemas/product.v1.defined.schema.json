{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductDefined",
  "description": "Event emitted when a new insurance product is defined in the catalog.",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "productId",
    "name",
    "productLine",
    "basePremium",
    "timestamp"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this event."
    },
    "eventType": {
      "type": "string",
      "enum": ["ProductDefined"],
      "description": "Discriminator for the event type."
    },
    "productId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the product."
    },
    "name": {
      "type": "string",
      "description": "Human-readable product name."
    },
    "productLine": {
      "type": "string",
      "description": "Product line classification (e.g. household, liability)."
    },
    "basePremium": {
      "type": "number",
      "description": "Base premium amount before risk adjustments."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the event occurred."
    }
  }
}
