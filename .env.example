# Copy this file to .env and fill in the values.
# .env is git-ignored; .env.example is committed as a template.
#
# All variables listed here are REQUIRED in the prod profile.
# Missing any of them will cause the service to fail fast at startup.

# ── Partner Service (port 9080) ──────────────────────────────────────────────
# JDBC connection URL for the partner database
DATABASE_URL=jdbc:postgresql://localhost:5432/partner_db
# Database credentials
DATABASE_USER=partner_user
DATABASE_PASSWORD=change_me

# ── Product Service (port 9081) ──────────────────────────────────────────────
# JDBC connection URL for the product database
PRODUCT_DATABASE_URL=jdbc:postgresql://localhost:5433/product_db
# Database credentials
PRODUCT_DATABASE_USER=product_user
PRODUCT_DATABASE_PASSWORD=change_me

# ── Policy Service (port 9082) ─────────────────────────────────────────────
# JDBC connection URL for the policy database
POLICY_DATABASE_URL=jdbc:postgresql://localhost:5434/policy_db
# Database credentials
POLICY_DATABASE_USER=policy_user
POLICY_DATABASE_PASSWORD=change_me

# ── Kafka (used by Policy Service consumers) ────────────────────────────────
# Comma-separated list of Kafka broker addresses
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── Schema Registry ─────────────────────────────────────────────────────────
# URL of the Confluent Schema Registry (used by Debezium connectors)
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ── Billing Service (port 9084) ──────────────────────────────────────────────
# JDBC connection URL for the billing database
BILLING_DATABASE_URL=jdbc:postgresql://localhost:5436/billing_db
# Database credentials
BILLING_DATABASE_USER=billing_user
BILLING_DATABASE_PASSWORD=change_me

# ── Infrastructure passwords (used in docker-compose.yaml) ──────────────────
PARTNER_DB_PASSWORD=change_me
PRODUCT_DB_PASSWORD=change_me
POLICY_DB_PASSWORD=change_me
BILLING_DB_PASSWORD=change_me
PLATFORM_DB_PASSWORD=change_me

# ── Container Image Configuration ──────────────────────────────────────────
IMAGE_REGISTRY=css
IMAGE_TAG=latest

# ── AKHQ (Kafka UI) ─────────────────────────────────────────────────────────
# JWT secret for AKHQ authentication (minimum 32 random characters)
AKHQ_JWT_SECRET=change_me_use_at_least_32_random_characters
