{
  "name": "trino-iceberg-ingestion",
  "displayName": "Iceberg Lakehouse (Trino)",
  "serviceType": "databaseService",
  "serviceConnection": {
    "config": {
      "type": "Trino",
      "hostPort": "trino:8086",
      "username": "openmetadata",
      "catalog": "iceberg",
      "databaseSchema": "analytics",
      "params": {}
    }
  },
  "sourceConfig": {
    "config": {
      "type": "DatabaseMetadata",
      "schemaFilterPattern": {
        "includes": [
          "analytics",
          "partner_raw",
          "product_raw",
          "policy_raw",
          "billing_raw",
          "claims_raw",
          "hr_raw",
          "partner_silver",
          "product_silver",
          "policy_silver",
          "billing_silver",
          "claims_silver",
          "hr_silver",
          "partner_gold",
          "policy_gold",
          "billing_gold",
          "claims_gold",
          "hr_gold"
        ]
      },
      "includeViews": true,
      "markDeletedTables": true,
      "includeTags": true
    }
  }
}
