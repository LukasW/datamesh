{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PolicyIssued",
  "description": "Event emitted when a new insurance policy is issued.",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "policyId",
    "policyNumber",
    "partnerId",
    "productId",
    "coverageStartDate",
    "premium",
    "timestamp"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this event."
    },
    "eventType": {
      "type": "string",
      "enum": ["PolicyIssued"],
      "description": "Discriminator for the event type."
    },
    "policyId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the policy."
    },
    "policyNumber": {
      "type": "string",
      "description": "Human-readable policy number."
    },
    "partnerId": {
      "type": "string",
      "format": "uuid",
      "description": "Identifier of the partner (policyholder)."
    },
    "productId": {
      "type": "string",
      "format": "uuid",
      "description": "Identifier of the associated product."
    },
    "coverageStartDate": {
      "type": "string",
      "format": "date",
      "description": "ISO-8601 date when the coverage begins."
    },
    "premium": {
      "type": "string",
      "description": "Premium amount as a decimal string (e.g. \"1234.56\")."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the event occurred."
    }
  }
}
