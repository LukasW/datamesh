{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CoverageAdded",
  "description": "Event emitted when a new coverage is added to an existing policy.",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "policyId",
    "coverageId",
    "coverageType",
    "insuredAmount",
    "timestamp"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this event."
    },
    "eventType": {
      "type": "string",
      "enum": ["CoverageAdded"],
      "description": "Discriminator for the event type."
    },
    "policyId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the policy."
    },
    "coverageId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the coverage."
    },
    "coverageType": {
      "type": "string",
      "description": "Type of coverage (e.g. fire, water, theft)."
    },
    "insuredAmount": {
      "type": "string",
      "description": "Insured amount as a decimal string (e.g. \"100000.00\")."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the event occurred."
    }
  }
}
