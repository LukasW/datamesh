{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PolicyCancelled",
  "description": "Event emitted when an existing policy is cancelled.",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "policyId",
    "policyNumber",
    "timestamp"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this event."
    },
    "eventType": {
      "type": "string",
      "enum": ["PolicyCancelled"],
      "description": "Discriminator for the event type."
    },
    "policyId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the policy."
    },
    "policyNumber": {
      "type": "string",
      "description": "Human-readable policy number."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the event occurred."
    }
  }
}
